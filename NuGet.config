<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet config for building the generated C# SDK on Twilio locked-down Buildkite
  agents. Public nuget.org is blocked, so resolve packages through Twilio's
  internal Artifactory NuGet mirror.

  virtual-nuget-twilio is the aggregate repo (internal + thirdparty), matching the
  npm choice of virtual-npm-twilio.
-->
<configuration>
  <packageSources>
    <!-- clear inherited/default nuget.org so only the mirror is used -->
    <clear />
    <add key="twilio-artifactory" value="https://nuget.artifacts.twilio.com/artifactory/api/nuget/v3/virtual-nuget-twilio/index.json" />
  </packageSources>
</configuration>
